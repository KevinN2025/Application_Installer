#!/bin/bash

if [ $# -ne 1 ]; then
  echo "Usage: $(basename "$0") <service>"
  exit 1
fi

service="$1"

if ! command -v systemctl >/dev/null 2>&1; then
  echo "systemctl is not available on this system"
  exit 1
fi

if ! systemctl list-unit-files --type=service | awk '{print $1}' | grep -Fxq "$service"; then
  if ! systemctl list-unit-files --type=service | awk '{print $1}' | grep -Fxq "${service}.service"; then
    echo "Service not found: $service"
    exit 1
  fi
  service="${service}.service"
fi

active_state=$(systemctl is-active "$service" 2>/dev/null || true)
enabled_state=$(systemctl is-enabled "$service" 2>/dev/null || true)

case "$active_state" in
  active)
    echo "$service is on"
    ;;
  inactive|failed|activating|deactivating)
    echo "$service is off"
    ;;
  *)
    echo "$service active state: $active_state"
    ;;
esac

case "$enabled_state" in
  enabled)
    echo "$service is enabled"
    ;;
  disabled)
    echo "$service is disabled"
    ;;
  *)
    echo "$service enabled state: $enabled_state"
    ;;
esac
