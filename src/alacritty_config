#!/bin/bash

set -e

REPO_URL="https://github.com/KevinN2025/alacritty.git"
ALACRITTY_CONFIG_DIR="${HOME}/.config/alacritty"

echo "Syncing Alacritty configuration from ${REPO_URL}"

mkdir -p "${HOME}/.config"

if [ -d "${ALACRITTY_CONFIG_DIR}/.git" ]; then
  echo "Existing Alacritty config repository found, pulling latest changes"
  git -C "${ALACRITTY_CONFIG_DIR}" pull --ff-only
elif [ -e "${ALACRITTY_CONFIG_DIR}" ]; then
  echo "Cannot install Alacritty config because ${ALACRITTY_CONFIG_DIR} exists and is not a git repository"
  exit 1
else
  echo "Cloning Alacritty config into ${ALACRITTY_CONFIG_DIR}"
  git clone "${REPO_URL}" "${ALACRITTY_CONFIG_DIR}"
fi

echo "Alacritty configuration is up to date"
